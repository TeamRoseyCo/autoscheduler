generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─── Auth.js required models ───

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  tasks         Task[]
  projects      Project[]
  scheduledBlocks ScheduledBlock[]
  preferences   Preferences?
  googleEventTransports GoogleEventTransport[]
  metricDefinitions MetricDefinition[]
  metricEntries     MetricEntry[]
  uniSettings    UniSettings?
  uniSemesters   UniSemester[]
  uniCourses     UniCourse[]
  uniClassSlots  UniClassSlot[]
  uniExams       UniExam[]
  uniGradeItems  UniGradeItem[]
  uniNotes       UniNote[]
  uniSummaries   UniClassSummary[]
  uniResources   UniResource[]
  uniMoodleSyncs UniMoodleSync[]
  habits          Habit[]
  habitGenerations HabitGeneration[]
  smartImportConfigs SmartImportConfig[]
  smartImportEvents  SmartImportEvent[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── App models ───

model Project {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  color       String   @default("indigo")
  status      String   @default("active") // active, completed, archived
  deadline    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks       Task[]
  habits      Habit[]
}

model Task {
  id                  String   @id @default(cuid())
  userId              String
  title               String
  durationMinutes     Int
  deadline            DateTime?
  deadlineTime        String?  // HH:MM — optional time for the deadline
  priority            String   @default("medium") // asap, high, medium, low
  energyType          String   @default("deep")   // deep, light, admin
  preferredTimeWindow String?  // e.g. "morning", "afternoon", "evening"
  completed           Boolean  @default(false)
  taskStatus          String   @default("todo")   // todo, in_progress, completed, cancelled, blocked
  projectId           String?
  metricId            String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project             Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  metric              MetricDefinition? @relation(fields: [metricId], references: [id])
  scheduledBlocks     ScheduledBlock[]
  metricEntries       MetricEntry[]
}

model ScheduledBlock {
  id              String    @id @default(cuid())
  userId          String
  taskId          String?
  googleEventId   String?
  title           String
  startTime       DateTime
  endTime         DateTime
  date            String    // YYYY-MM-DD for easy querying
  color           String    @default("indigo")
  status          String    @default("scheduled") // "scheduled" | "in_progress" | "completed"
  availability    String    @default("busy") // "busy" | "free_tight" | "free_light" | "free"
  actualStartTime DateTime?
  actualEndTime   DateTime?
  location        String?   // destination address of this event
  transportBefore Int?      // travel minutes before event
  transportAfter  Int?      // travel minutes after event
  transportMode   String?   // "driving" | "transit" | "walking" | "cycling"
  locked          Boolean   @default(false)
  createdAt       DateTime  @default(now())
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  task            Task?     @relation(fields: [taskId], references: [id], onDelete: SetNull)
}

model GoogleEventTransport {
  id              String   @id @default(cuid())
  userId          String
  googleEventId   String
  location        String?
  transportBefore Int?
  transportAfter  Int?
  transportMode   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, googleEventId])
}

model Preferences {
  id             String @id @default(cuid())
  userId         String @unique
  workStartTime  String @default("09:00") // HH:mm
  workEndTime    String @default("17:00")
  workDays       String @default("1,2,3,4,5") // comma-separated day numbers (1=Mon)
  deepWorkStart  String @default("09:00")
  deepWorkEnd    String @default("12:00")
  breakMinutes   Int    @default(5)
  timezone       String @default("America/New_York")
  aiProvider       String @default("gemini") // "openai" | "gemini"
  openaiApiKey     String?
  openaiModel      String @default("gemini-2.0-flash")
  googleMapsApiKey String?  // user's Google Maps API key
  savedPlaces      String?  // JSON: [{name, address}]
  user             User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MetricDefinition {
  id          String        @id @default(cuid())
  userId      String
  name        String        // "Dials", "Distance Run", "Videos Produced"
  unit        String        // "calls", "km", "videos"
  icon        String        // emoji e.g. "📞", "🏃", "🎬"
  category    String        // "sales", "fitness", "content", "finance", etc.
  aggregation String        @default("sum") // "sum" | "max" | "avg" | "last"
  isPreset    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries     MetricEntry[]
  tasks       Task[]
}

model MetricEntry {
  id          String           @id @default(cuid())
  userId      String
  metricId    String
  taskId      String?
  value       Float
  date        DateTime         @default(now())
  notes       String?
  createdAt   DateTime         @default(now())
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  metric      MetricDefinition @relation(fields: [metricId], references: [id], onDelete: Cascade)
  task        Task?            @relation(fields: [taskId], references: [id])
}

// ─── UniTracker Plugin Models ───

model UniSettings {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  enabled         Boolean  @default(false)
  universityName  String?
  studentName     String?
  gradeScale      String   @default("4.0")   // "4.0"|"4.3"|"percentage"|"custom"
  targetGPA       Float?
  moodleUrl       String?
  moodleToken     String?
  moodleUserId    Int?
  stagUrl         String?                    // e.g. "https://stagservices.upol.cz"
  stagTicket      String?                    // login ticket for STAG API
  stagOsCislo     String?                    // student personal number
  stagUser        String?                    // stagUser role identifier (e.g. "F12345")
  customScaleJson String?                    // JSON: [{letter, minPercent, gpa}]
  aiProvider      String?                    // "gemini"|"openai"
  aiApiKey        String?
  aiModel         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model UniSemester {
  id        String   @id @default(cuid())
  userId    String
  name      String   // "Fall 2025", "Spring 2026"
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courses   UniCourse[]
}

model UniCourse {
  id             String   @id @default(cuid())
  userId         String
  semesterId     String
  code           String   // "CS101", "MATH201"
  name           String
  professor      String?
  room           String?
  credits        Int?
  color          String   @default("indigo")
  status         String   @default("active") // "active", "completed", "dropped"
  moodleCourseId Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  semester       UniSemester @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  classSlots     UniClassSlot[]
  exams          UniExam[]
  gradeItems     UniGradeItem[]
  notes          UniNote[]
  summaries      UniClassSummary[]
  resources      UniResource[]
}

model UniClassSlot {
  id         String   @id @default(cuid())
  userId     String
  courseId   String
  dayOfWeek  Int      // 0-6 (0=Sunday, 1=Monday, etc.)
  startTime  String   @default("09:00") // HH:MM
  endTime    String   @default("10:00")
  type       String   @default("lecture") // "lecture", "lab", "tutorial", "seminar"
  location   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course     UniCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model UniExam {
  id              String   @id @default(cuid())
  userId          String
  courseId        String
  title           String
  type            String   @default("exam") // "exam", "assignment", "project", "quiz"
  date            DateTime
  time            String?  // HH:MM
  location        String?
  weight          Float?   // percentage weight in grade
  notes           String?
  completed       Boolean  @default(false)
  calendarBlockId String?  // ID of auto-created ScheduledBlock (no FK)
  studyTaskId     String?  // ID of auto-created Task (no FK)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course          UniCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model UniGradeItem {
  id         String   @id @default(cuid())
  userId     String
  courseId   String?  // nullable for general grade items
  name       String
  category   String?  // "midterm", "final", "homework", etc.
  weight     Float?   // percentage weight in course grade
  maxScore   Float
  score      Float?
  date       DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course     UniCourse? @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model UniNote {
  id        String   @id @default(cuid())
  userId    String
  courseId  String?  // nullable for general notes
  title     String
  content   String   // markdown
  tags      String?  // CSV tags
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    UniCourse? @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model UniClassSummary {
  id              String   @id @default(cuid())
  userId          String
  courseId        String?  // nullable for general summaries
  date            DateTime
  type            String   @default("lecture") // "lecture", "lab", "tutorial"
  topics          String?  // CSV or markdown list
  summary         String?  // main summary/notes
  keyTakeaways    String?  // markdown bullet points
  questions       String?  // unanswered questions
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course          UniCourse? @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model UniResource {
  id         String   @id @default(cuid())
  userId     String
  courseId   String?  // nullable for general resources
  title      String
  url        String?
  type       String   @default("link") // "link", "file", "textbook", "video", "website"
  category   String?
  notes      String?
  starred    Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course     UniCourse? @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model UniMoodleSync {
  id           String   @id @default(cuid())
  userId       String
  dataType     String   // "courses", "assignments", "resources", "grades"
  lastSyncAt   DateTime?
  status       String   @default("pending") // "pending", "syncing", "success", "error"
  itemCount    Int      @default(0)
  error        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dataType])
}

// ─── Habit Generator Models ───

model Habit {
  id              String   @id @default(cuid())
  userId          String
  title           String
  emoji           String   @default("🔄")
  durationMinutes Int      @default(30)
  frequency       String   @default("daily") // "daily" | "weekdays" | "1,3,5" (CSV day numbers, 0=Sun)
  projectId       String?
  preferredTime   String?  // "morning" | "afternoon" | "evening"
  energyType      String   @default("light")
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project         Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
}

// ─── Smart Import v2 Models ───

model SmartImportConfig {
  id              String   @id @default(cuid())
  userId          String
  name            String
  sourceType      String   // "gmail"
  enabled         Boolean  @default(true)
  gmailQuery      String?
  lastScanAt      DateTime?
  lastScanStatus  String?  // "success" | "error" | "scanning"
  lastScanError   String?
  lastScanCount   Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pendingEvents   SmartImportEvent[]
}

model SmartImportEvent {
  id               String   @id @default(cuid())
  userId           String
  configId         String?
  title            String
  date             String   // YYYY-MM-DD
  startTime        String   // HH:MM
  endTime          String   // HH:MM
  location         String?
  description      String?
  eventType        String   // meeting|travel|appointment|social|deadline|reminder|class|other
  color            String   @default("gray")
  confidence       Float    @default(0.7)
  source           String   // "text" | "ics" | "email" | "gmail" | "natural_language"
  sourceRef        String?  // Gmail message ID for dedup
  status           String   @default("pending") // "pending" | "approved" | "rejected" | "created"
  suggestedByAI    Boolean  @default(false)
  scheduledBlockId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  config           SmartImportConfig? @relation(fields: [configId], references: [id], onDelete: SetNull)
}

model HabitGeneration {
  id        String   @id @default(cuid())
  userId    String
  habitId   String
  taskId    String
  weekStart String   // "YYYY-MM-DD" Monday of target week
  date      String   // "YYYY-MM-DD" specific day
  status    String   @default("pending") // "pending" | "completed" | "skipped" | "rescheduled"
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
}
