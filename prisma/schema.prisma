generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─── Auth.js required models ───

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  tasks         Task[]
  projects      Project[]
  scheduledBlocks ScheduledBlock[]
  preferences   Preferences?
  googleEventTransports GoogleEventTransport[]
  metricDefinitions MetricDefinition[]
  metricEntries     MetricEntry[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── App models ───

model Project {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  color       String   @default("indigo")
  status      String   @default("active") // active, completed, archived
  deadline    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks       Task[]
}

model Task {
  id                  String   @id @default(cuid())
  userId              String
  title               String
  durationMinutes     Int
  deadline            DateTime?
  priority            String   @default("medium") // asap, high, medium, low
  energyType          String   @default("deep")   // deep, light, admin
  preferredTimeWindow String?  // e.g. "morning", "afternoon", "evening"
  completed           Boolean  @default(false)
  taskStatus          String   @default("todo")   // todo, in_progress, completed, cancelled, blocked
  projectId           String?
  metricId            String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project             Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  metric              MetricDefinition? @relation(fields: [metricId], references: [id])
  scheduledBlocks     ScheduledBlock[]
  metricEntries       MetricEntry[]
}

model ScheduledBlock {
  id              String    @id @default(cuid())
  userId          String
  taskId          String?
  googleEventId   String?
  title           String
  startTime       DateTime
  endTime         DateTime
  date            String    // YYYY-MM-DD for easy querying
  color           String    @default("indigo")
  status          String    @default("scheduled") // "scheduled" | "in_progress" | "completed"
  availability    String    @default("busy") // "busy" | "free_tight" | "free_light" | "free"
  actualStartTime DateTime?
  actualEndTime   DateTime?
  location        String?   // destination address of this event
  transportBefore Int?      // travel minutes before event
  transportAfter  Int?      // travel minutes after event
  transportMode   String?   // "driving" | "transit" | "walking" | "cycling"
  createdAt       DateTime  @default(now())
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  task            Task?     @relation(fields: [taskId], references: [id], onDelete: SetNull)
}

model GoogleEventTransport {
  id              String   @id @default(cuid())
  userId          String
  googleEventId   String
  location        String?
  transportBefore Int?
  transportAfter  Int?
  transportMode   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, googleEventId])
}

model Preferences {
  id             String @id @default(cuid())
  userId         String @unique
  workStartTime  String @default("09:00") // HH:mm
  workEndTime    String @default("17:00")
  workDays       String @default("1,2,3,4,5") // comma-separated day numbers (1=Mon)
  deepWorkStart  String @default("09:00")
  deepWorkEnd    String @default("12:00")
  breakMinutes   Int    @default(5)
  timezone       String @default("America/New_York")
  aiProvider       String @default("gemini") // "openai" | "gemini"
  openaiApiKey     String?
  openaiModel      String @default("gemini-2.0-flash")
  googleMapsApiKey String?  // user's Google Maps API key
  savedPlaces      String?  // JSON: [{name, address}]
  user             User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MetricDefinition {
  id          String        @id @default(cuid())
  userId      String
  name        String        // "Dials", "Distance Run", "Videos Produced"
  unit        String        // "calls", "km", "videos"
  icon        String        // emoji e.g. "📞", "🏃", "🎬"
  category    String        // "sales", "fitness", "content", "finance", etc.
  aggregation String        @default("sum") // "sum" | "max" | "avg" | "last"
  isPreset    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries     MetricEntry[]
  tasks       Task[]
}

model MetricEntry {
  id          String           @id @default(cuid())
  userId      String
  metricId    String
  taskId      String?
  value       Float
  date        DateTime         @default(now())
  notes       String?
  createdAt   DateTime         @default(now())
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  metric      MetricDefinition @relation(fields: [metricId], references: [id], onDelete: Cascade)
  task        Task?            @relation(fields: [taskId], references: [id])
}
