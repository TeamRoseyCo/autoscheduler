{
  "name": "auto-scheduler",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "author": "AutoScheduler",
  "description": "AI-powered calendar scheduling assistant",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron": "electron .",
    "electron:dev": "electron .",
    "dist": "next build && electron-builder",
    "dist:win": "next build && electron-builder --win",
    "postinstall": "npx prisma generate"
  },
  "build": {
    "appId": "com.autoscheduler.app",
    "productName": "AutoScheduler",
    "npmRebuild": false,
    "asar": false,
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "public/**/*",
      ".next/**/*",
      "node_modules/**/*",
      "package.json",
      "next.config.*",
      "prisma/**/*",
      ".env*"
    ],
    "win": {
      "target": "portable",
      "icon": "public/icon.ico"
    }
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@prisma/adapter-better-sqlite3": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.3.1",
    "googleapis": "^171.4.0",
    "next": "16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "openai": "^6.24.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.7.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^7.4.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
